class SlugGenerator {
  generuj(tytul) {
    return tytul
      .toLowerCase()
      .replace(/[^\w\s]/g, "")
      .replace(/\s+/g, "-");
  }
}

let slug = new SlugGenerator();
console.log(slug.generuj("Co to jest OOP?"));


class Analizator {
  liczSamogloski(tekst) {
    let sam = "aeiouy";
    let licznik = 0;

    for (let i = 0; i < tekst.length; i++) {
      if (sam.includes(tekst[i].toLowerCase())) {
        licznik++;
      }
    }
    return licznik;
  }
}

let a = new Analizator();
console.log("Samogłoski:", a.liczSamogloski("Programowanie jest super"));


// odwracanie stringa
function odwroc(str) {
  let wynik = "";
  for (let i = str.length - 1; i >= 0; i--) {
    wynik += str[i];
  }
  return wynik;
}

console.log(odwroc("ABC")); 
