document.body.innerHTML += `
<input id="pesel" placeholder="PESEL">
<button id="btn">Sprawdź</button>
<p id="wynik"></p>
`;

document.getElementById("btn").onclick = function () {
  let pesel = document.getElementById("pesel").value;
  let wynik = document.getElementById("wynik");

  if (pesel.length === 11) {
    wynik.style.color = "green";
    wynik.textContent = maskujPesel(pesel);
  } else {
    wynik.style.color = "red";
    wynik.textContent = "Błąd";
  }
};

function maskujPesel(pesel) {
  let ostatnie = pesel.slice(-4);
  return "*******" + ostatnie;
}


