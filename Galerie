<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>Galeria JS</title>
<style>
  img { width: 300px; height: 200px; display: block; margin-bottom: 10px; }
</style>
</head>
<body>

<h2>Galeria</h2>

<img id="foto" src="https://picsum.photos/id/101/300/200">
<p id="licznik"></p>

<button onclick="zmien()">Zmień zdjęcie</button>
<button onclick="reset()">Reset</button>
<br><br>
<button onclick="poprzednie()">Poprzednie</button>
<button onclick="nastepne()">Następne</button>

<script>

// POZIOM 1

let img = document.getElementById("foto");

function zmien() {
  img.src = "https://picsum.photos/id/104/300/200";
}

function reset() {
  img.src = "https://picsum.photos/id/101/300/200";
}

//////////////////////////////////////////////////
// POZIOM 2 – TABLICA
//////////////////////////////////////////////////

let zdjecia = [
  "https://picsum.photos/id/101/300/200",
  "https://picsum.photos/id/102/300/200",
  "https://picsum.photos/id/103/300/200"
];

let index = 0;

//////////////////////////////////////////////////
// POZIOM 3 – NAWIGACJA + PĘTLA
//////////////////////////////////////////////////

let licznik = document.getElementById("licznik");

function nastepne() {
  index++;
  if (index >= zdjecia.length) {
    index = 0;
  }
  img.src = zdjecia[index];
  pokazLicznik();
}

function poprzednie() {
  index--;
  if (index < 0) {
    index = zdjecia.length - 1;
  }
  img.src = zdjecia[index];
  pokazLicznik();
}

function pokazLicznik() {
  licznik.textContent = "Zdjęcie " + (index + 1) + " z " + zdjecia.length;
}

//////////////////////////////////////////////////
// POZIOM 4 – KLASA + AUTOMAT
//////////////////////////////////////////////////

class Galeria {
  constructor(tablica, id) {
    this.zdjecia = tablica;
    this.index = 0;
    this.img = document.getElementById(id);
  }

  nastepne() {
    this.index++;
    if (this.index >= this.zdjecia.length) {
      this.index = 0;
    }
    this.img.src = this.zdjecia[this.index];
  }

  poprzednie() {
    this.index--;
    if (this.index < 0) {
      this.index = this.zdjecia.length - 1;
    }
    this.img.src = this.zdjecia[this.index];
  }

  autoPlay() {
    setInterval(() => {
      this.nastepne();
    }, 3000);
  }
}

// użycie klasy
let galeria = new Galeria(zdjecia, "foto");
galeria.autoPlay();

pokazLicznik();

</script>

</body>
</html>
