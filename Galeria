<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>Galeria</title>
<style>
  body {
    font-family: Arial;
    text-align: center;
    background: #f5f5f5;
  }
  img {
    width: 300px;
    height: 200px;
    object-fit: cover;
    border: 3px solid #333;
    margin: 10px;
  }
  button {
    padding: 8px 12px;
    margin: 5px;
    cursor: pointer;
  }
</style>
</head>
<body>

<h2>Galeria</h2>

<img id="mainImg" src="https://picsum.photos/id/1015/300/200">

<br>

<button onclick="changeImage()">Zmień zdjęcie</button>
<button onclick="resetImage()">Reset</button>

<br>

<button onclick="prevImage()">Poprzednie</button>
<button onclick="nextImage()">Następne</button>

<p id="counter"></p>

<script>
// Poziom 1
const defaultImg = "https://picsum.photos/id/1015/300/200";

function changeImage() {
  document.getElementById("mainImg").src = "https://picsum.photos/id/1025/300/200";
}

function resetImage() {
  document.getElementById("mainImg").src = defaultImg;
}

// Poziom 2
const images = [
  "https://picsum.photos/id/1015/300/200",
  "https://picsum.photos/id/1025/300/200",
  "https://picsum.photos/id/1035/300/200"
];

let index = 0;

function nextImage() {
  index++;
  if (index >= images.length) index = 0;
  document.getElementById("mainImg").src = images[index];
}

// Poziom 3
function updateImage() {
  document.getElementById("mainImg").src = images[index];
  document.getElementById("counter").innerText = `Zdjęcie ${index + 1} z ${images.length}`;
}

function nextImage() {
  index++;
  if (index >= images.length) index = 0;
  updateImage();
}

function prevImage() {
  index--;
  if (index < 0) index = images.length - 1;
  updateImage();
}

// Poziom 4
class Gallery {
  constructor(imgArray, imgId) {
    this.images = imgArray;
    this.index = 0;
    this.imgEl = document.getElementById(imgId);
  }
  next() {
    this.index = (this.index + 1) % this.images.length;
    this.show();
  }
  prev() {
    this.index = (this.index - 1 + this.images.length) % this.images.length;
    this.show();
  }
  show() {
    this.imgEl.src = this.images[this.index];
  }
  autoPlay() {
    setInterval(() => this.next(), 3000);
  }
}

const gallery = new Gallery(images, "mainImg");
gallery.autoPlay();

updateImage();

</script>

</body>
</html>
