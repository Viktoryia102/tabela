function updateImage() {
  document.getElementById("mainImg").src = images[index];
  document.getElementById("counter").innerText = `Zdjęcie ${index + 1} z ${images.length}`;
}

function nextImage() {
  index++;
  if (index >= images.length) index = 0;
  updateImage();
}

function prevImage() {
  index--;
  if (index < 0) index = images.length - 1;
  updateImage();
}
