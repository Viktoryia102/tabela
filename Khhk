class Pracownik {

    // ===== POLA =====
    private String imie;
    private String nazwisko;
    private double wynagrodzenie;

    // ===== KONSTRUKTOR =====
    public Pracownik(String imie, String nazwisko, double wynagrodzenie) {
        this.imie = imie;
        this.nazwisko = nazwisko;
        this.wynagrodzenie = wynagrodzenie;
    }

    // ===== GETTERY =====
    public String getImie() {
        return imie;
    }

    public String getNazwisko() {
        return nazwisko;
    }

    // ===== OCENA 3 =====
    public double getRoczneWynagrodzenie() {
        return wynagrodzenie * 12;
    }

    // ===== OCENA 4 + 5 =====
    public void zmienWynagrodzenie(double noweWynagrodzenie) {

        // brak obniżek
        if (noweWynagrodzenie <= wynagrodzenie) {
            return;
        }

        // max +20%
        double maxWynagrodzenie = wynagrodzenie * 1.2;

        if (noweWynagrodzenie > maxWynagrodzenie) {
            wynagrodzenie = maxWynagrodzenie;
            System.out.println("Zbyt duża podwyżka, przyznano max 20%");
        } else {
            wynagrodzenie = noweWynagrodzenie;
        }
    }

    public double getWynagrodzenie() {
        return wynagrodzenie;
    }
}

// ===== KLASA STARTOWA =====
public class Main {

    public static void main(String[] args) {

        Pracownik p = new Pracownik("Jan", "Kowalski", 5000);

        System.out.println("Pracownik: " + p.getImie() + " " + p.getNazwisko());
        System.out.println("Miesięczna pensja: " + p.getWynagrodzenie());
        System.out.println("Roczna pensja: " + p.getRoczneWynagrodzenie());

        System.out.println("\nPodwyżka do 6000:");
        p.zmienWynagrodzenie(6000);
        System.out.println("Aktualna pensja: " + p.getWynagrodzenie());

        System.out.println("\nPróba podwyżki do 9000:");
        p.zmienWynagrodzenie(9000);
        System.out.println("Aktualna pensja: " + p.getWynagrodzenie());
    }
} 
